{
  "name": "philharmonic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Coding Agent Orchestration Engine",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:orchestrator": "pnpm --filter @phil/orchestrator dev",
    "dev:dashboard": "pnpm --filter @phil/dashboard dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}